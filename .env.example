# ─────────────────────────────────────────────────────────────
# TradIA — Backend Environment Variables
# Copy this to .env and fill in real values.
# Never commit .env to Git.
# ─────────────────────────────────────────────────────────────

# ── Trading Mode ─────────────────────────────────────────────
PAPER_MODE=true                          # true = paper mode (safe), false = live trading
BINANCE_TESTNET=false                    # true = use Binance testnet

# ── Exchange Credentials (optional — users connect via UI) ───
EXCHANGE=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Security ─────────────────────────────────────────────────
# 32-byte random hex string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIAL_STORE_KEY=REPLACE_WITH_RANDOM_32_BYTE_HEX

# ── API ───────────────────────────────────────────────────────
API_PORT=8000

# ── Frontend URL (for CORS) ───────────────────────────────────
# Add your Vercel deployment URL here:
FRONTEND_URL=https://your-app.vercel.app
